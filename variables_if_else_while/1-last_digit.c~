*/

int main(void)
{
	int n;
	int lastnum;

	srand(time(0));
	n = rand() - RAND_MAX / 2;
	lastnum = n % 10;
	
	if (n > 5)
	{
		printf("Last digit of %d is %d\n", n, lastnum);
	}
	else if (n == 0)
	{
		printf("Last digit of %d is %d\n", n, lastnum);
	}
	else if (n < 6 && lastnum != 0)
	{
		printf("Last digit of %d is %d\n", n, lastnum);
	}
	return (0);
}
